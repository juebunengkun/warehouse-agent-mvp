{
  "tables": [
    {
      "name": "ods_sales_event_di",
      "layer": "ODS",
      "description": "销售业务原始事件表，按业务日期 dt 分区，包含曝光、点击、下单、支付和退款事件。",
      "fields": [
        {"name": "order_id", "type": "STRING", "comment": "订单 ID"},
        {"name": "user_id", "type": "STRING", "comment": "支付用户 ID"},
        {"name": "sku_id", "type": "STRING", "comment": "商品 SKU ID"},
        {"name": "gmv_amount", "type": "DECIMAL(18,2)", "comment": "GMV"},
        {"name": "pay_amount", "type": "DECIMAL(18,2)", "comment": "实付金额"},
        {"name": "discount_amount", "type": "DECIMAL(18,2)", "comment": "优惠金额"},
        {"name": "refund_amount", "type": "DECIMAL(18,2)", "comment": "退款金额"},
        {"name": "order_status", "type": "STRING", "comment": "订单状态"},
        {"name": "exposure_user_id", "type": "STRING", "comment": "曝光用户 ID"},
        {"name": "click_user_id", "type": "STRING", "comment": "点击用户 ID"},
        {"name": "order_user_id", "type": "STRING", "comment": "下单用户 ID"},
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "channel_type", "type": "STRING", "comment": "渠道类型"},
        {"name": "region_id", "type": "STRING", "comment": "地区 ID"},
        {"name": "region_name", "type": "STRING", "comment": "地区名称"},
        {"name": "province_name", "type": "STRING", "comment": "省份名称"},
        {"name": "city_name", "type": "STRING", "comment": "城市名称"},
        {"name": "user_type", "type": "STRING", "comment": "新老用户"},
        {"name": "member_level", "type": "STRING", "comment": "会员等级"},
        {"name": "event_time", "type": "STRING", "comment": "事件时间"},
        {"name": "is_valid", "type": "TINYINT", "comment": "是否有效记录"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dwd_sales_detail_di",
      "layer": "DWD",
      "description": "清洗后的销售订单明细事实表，承接 ODS 原始事件并统一渠道、地域和用户标签。",
      "fields": [
        {"name": "order_id", "type": "STRING", "comment": "订单 ID"},
        {"name": "user_id", "type": "STRING", "comment": "支付用户 ID"},
        {"name": "sku_id", "type": "STRING", "comment": "商品 SKU ID"},
        {"name": "gmv_amount", "type": "DECIMAL(18,2)", "comment": "GMV"},
        {"name": "pay_amount", "type": "DECIMAL(18,2)", "comment": "实付金额"},
        {"name": "discount_amount", "type": "DECIMAL(18,2)", "comment": "优惠金额"},
        {"name": "refund_amount", "type": "DECIMAL(18,2)", "comment": "退款金额"},
        {"name": "order_status", "type": "STRING", "comment": "订单状态"},
        {"name": "exposure_user_id", "type": "STRING", "comment": "曝光用户 ID"},
        {"name": "click_user_id", "type": "STRING", "comment": "点击用户 ID"},
        {"name": "order_user_id", "type": "STRING", "comment": "下单用户 ID"},
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "channel_type", "type": "STRING", "comment": "渠道类型"},
        {"name": "region_id", "type": "STRING", "comment": "地区 ID"},
        {"name": "region_name", "type": "STRING", "comment": "地区名称"},
        {"name": "province_name", "type": "STRING", "comment": "省份名称"},
        {"name": "city_name", "type": "STRING", "comment": "城市名称"},
        {"name": "user_type", "type": "STRING", "comment": "新老用户"},
        {"name": "member_level", "type": "STRING", "comment": "会员等级"},
        {"name": "pay_time", "type": "STRING", "comment": "支付时间"},
        {"name": "stat_date", "type": "STRING", "comment": "统计日期"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dws_sales_day_summary_di",
      "layer": "DWS",
      "description": "按天、地区、渠道聚合的销售主题汇总表，适合基础销售日报复用。",
      "grain": "stat_date + region_id + channel_id",
      "fields": [
        {"name": "stat_date", "type": "STRING", "comment": "统计日期"},
        {"name": "region_id", "type": "STRING", "comment": "地区 ID"},
        {"name": "region_name", "type": "STRING", "comment": "地区名称"},
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "sales_amount", "type": "DECIMAL(18,2)", "comment": "销售额"},
        {"name": "order_count", "type": "BIGINT", "comment": "订单数"},
        {"name": "pay_user_count", "type": "BIGINT", "comment": "支付用户数"},
        {"name": "avg_order_amount", "type": "DECIMAL(18,2)", "comment": "客单价"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dwd_user_visit_log_di",
      "layer": "DWD",
      "description": "用户访问行为明细表，覆盖曝光、点击、渠道、地域、新老用户和会员等级标签。",
      "fields": [
        {"name": "event_id", "type": "STRING", "comment": "事件 ID"},
        {"name": "event_type", "type": "STRING", "comment": "事件类型：EXPOSURE/CLICK"},
        {"name": "user_id", "type": "STRING", "comment": "用户 ID"},
        {"name": "exposure_user_id", "type": "STRING", "comment": "曝光用户 ID"},
        {"name": "click_user_id", "type": "STRING", "comment": "点击用户 ID"},
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "channel_type", "type": "STRING", "comment": "渠道类型"},
        {"name": "province_name", "type": "STRING", "comment": "省份名称"},
        {"name": "city_name", "type": "STRING", "comment": "城市名称"},
        {"name": "user_type", "type": "STRING", "comment": "新老用户"},
        {"name": "member_level", "type": "STRING", "comment": "会员等级"},
        {"name": "event_time", "type": "STRING", "comment": "事件时间"},
        {"name": "stat_date", "type": "STRING", "comment": "统计日期"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dws_trade_channel_day_summary_di",
      "layer": "DWS",
      "description": "渠道经营日报公共汇总表，覆盖曝光UV、点击UV、下单用户数、支付用户数、支付订单数、GMV、实付金额、优惠金额、退款金额、支付转化率、客单价和 ARPU。",
      "grain": "stat_date + channel_id + channel_type + province_name + city_name + user_type + member_level",
      "fields": [
        {"name": "stat_date", "type": "STRING", "comment": "统计日期"},
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "channel_type", "type": "STRING", "comment": "渠道类型"},
        {"name": "province_name", "type": "STRING", "comment": "省份名称"},
        {"name": "city_name", "type": "STRING", "comment": "城市名称"},
        {"name": "user_type", "type": "STRING", "comment": "新老用户"},
        {"name": "member_level", "type": "STRING", "comment": "会员等级"},
        {"name": "exposure_uv", "type": "BIGINT", "comment": "曝光UV"},
        {"name": "click_uv", "type": "BIGINT", "comment": "点击UV"},
        {"name": "order_user_count", "type": "BIGINT", "comment": "下单用户数"},
        {"name": "pay_user_count", "type": "BIGINT", "comment": "支付用户数"},
        {"name": "pay_order_count", "type": "BIGINT", "comment": "支付订单数"},
        {"name": "gmv_amount", "type": "DECIMAL(18,2)", "comment": "GMV"},
        {"name": "pay_amount", "type": "DECIMAL(18,2)", "comment": "实付金额"},
        {"name": "discount_amount", "type": "DECIMAL(18,2)", "comment": "优惠金额"},
        {"name": "refund_amount", "type": "DECIMAL(18,2)", "comment": "退款金额"},
        {"name": "pay_conversion_rate", "type": "DECIMAL(18,6)", "comment": "支付转化率"},
        {"name": "avg_order_amount", "type": "DECIMAL(18,2)", "comment": "客单价"},
        {"name": "arpu", "type": "DECIMAL(18,2)", "comment": "ARPU"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "ads_channel_operation_daily_report_di",
      "layer": "ADS",
      "description": "渠道经营分析日报 ADS 表，供 BI 和运营看板查询。",
      "grain": "stat_date + channel_id + province_name + city_name + user_type + member_level",
      "fields": [
        {"name": "stat_date", "type": "STRING", "comment": "统计日期"},
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "channel_type", "type": "STRING", "comment": "渠道类型"},
        {"name": "province_name", "type": "STRING", "comment": "省份名称"},
        {"name": "city_name", "type": "STRING", "comment": "城市名称"},
        {"name": "user_type", "type": "STRING", "comment": "新老用户"},
        {"name": "member_level", "type": "STRING", "comment": "会员等级"},
        {"name": "exposure_uv", "type": "BIGINT", "comment": "曝光UV"},
        {"name": "click_uv", "type": "BIGINT", "comment": "点击UV"},
        {"name": "order_user_count", "type": "BIGINT", "comment": "下单用户数"},
        {"name": "pay_user_count", "type": "BIGINT", "comment": "支付用户数"},
        {"name": "pay_order_count", "type": "BIGINT", "comment": "支付订单数"},
        {"name": "gmv_amount", "type": "DECIMAL(18,2)", "comment": "GMV"},
        {"name": "pay_amount", "type": "DECIMAL(18,2)", "comment": "实付金额"},
        {"name": "discount_amount", "type": "DECIMAL(18,2)", "comment": "优惠金额"},
        {"name": "refund_amount", "type": "DECIMAL(18,2)", "comment": "退款金额"},
        {"name": "pay_conversion_rate", "type": "DECIMAL(18,6)", "comment": "支付转化率"},
        {"name": "avg_order_amount", "type": "DECIMAL(18,2)", "comment": "客单价"},
        {"name": "arpu", "type": "DECIMAL(18,2)", "comment": "ARPU"},
        {"name": "update_time", "type": "STRING", "comment": "更新时间"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dim_region_df",
      "layer": "DIM",
      "description": "地区维表，全量快照。",
      "fields": [
        {"name": "region_id", "type": "STRING", "comment": "地区 ID"},
        {"name": "region_name", "type": "STRING", "comment": "地区名称"},
        {"name": "province_name", "type": "STRING", "comment": "省份名称"},
        {"name": "city_name", "type": "STRING", "comment": "城市名称"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dim_channel_df",
      "layer": "DIM",
      "description": "渠道维表，全量快照。",
      "fields": [
        {"name": "channel_id", "type": "STRING", "comment": "渠道 ID"},
        {"name": "channel_name", "type": "STRING", "comment": "渠道名称"},
        {"name": "channel_type", "type": "STRING", "comment": "渠道类型"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    },
    {
      "name": "dim_user_profile_df",
      "layer": "DIM",
      "description": "用户画像维表，全量快照，提供新老用户和会员等级标签。",
      "fields": [
        {"name": "user_id", "type": "STRING", "comment": "用户 ID"},
        {"name": "user_type", "type": "STRING", "comment": "新老用户"},
        {"name": "member_level", "type": "STRING", "comment": "会员等级"},
        {"name": "register_date", "type": "STRING", "comment": "注册日期"},
        {"name": "dt", "type": "STRING", "comment": "分区日期"}
      ]
    }
  ]
}
