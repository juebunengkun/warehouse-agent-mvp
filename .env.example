OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
WAREHOUSE_AGENT_USE_LLM=false
WAREHOUSE_METADATA_PROVIDER=local_json

# Optional DataHub MCP integration.
DATAHUB_MCP_ENABLED=false
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=your_datahub_personal_access_token
DATAHUB_MCP_COMMAND=uvx
DATAHUB_MCP_PACKAGE=mcp-server-datahub@latest
DATAHUB_TIMEOUT=10
